  <availability-zone title="Availability Zone">
    <row gap="16">
      <col span="6" class="pa-2">
        <card title="Resource A" />
      </col>
      <col span="6" class="pa-2">
        <card title="Resource B" />
      </col>
    </row>
  </availability-zone>
</frame>
