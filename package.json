{
  "name": "xaligo-workspace",
  "private": true,
  "workspaces": [
    "packages/xaligo",
    "packages/xaligo-wasm",
    "packages/xaligo-darwin-arm64",
    "packages/xaligo-darwin-x64",
    "packages/xaligo-linux-arm64",
    "packages/xaligo-linux-x64",
    "packages/xaligo-win32-x64"
