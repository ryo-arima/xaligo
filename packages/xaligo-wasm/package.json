{
  "name": "@xaligo/xaligo-wasm",
  "version": "0.1.0",
  "description": "WebAssembly build of xaligo — convert .xal DSL to Excalidraw JSON from TypeScript/JavaScript",
  "keywords": [
    "xaligo",
    "excalidraw",
    "aws",
    "architecture-diagram",
    "wasm",
    "webassembly",
    "vscode-extension"
  ],
  "homepage": "https://github.com/ryo-arima/xaligo",
  "bugs": {
    "url": "https://github.com/ryo-arima/xaligo/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ryo-arima/xaligo.git",
    "directory": "packages/xaligo-wasm"
  },
  "license": "MIT",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "require": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist",
    "wasm"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "clean": "rimraf dist"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "rimraf": "^5.0.0",
    "tsup": "^8.0.0",
    "typescript": "^5.4.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
